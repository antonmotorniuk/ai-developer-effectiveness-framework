{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/ai-effectiveness/config.schema.json",
  "title": "AI Effectiveness Config",
  "type": "object",
  "required": [
    "schema_version",
    "methodology_name",
    "purpose",
    "dimensions",
    "score_range"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "methodology_name": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "not_for": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dimensions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "score_range": {
      "type": "object",
      "properties": {
        "dimension_min": {
          "type": "number"
        },
        "dimension_max": {
          "type": "number"
        },
        "overall_min": {
          "type": "number"
        },
        "overall_max": {
          "type": "number"
        }
      }
    }
  }
}
